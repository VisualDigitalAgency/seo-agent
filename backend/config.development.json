{
  "model": {
    "provider": "openrouter",
    "model": "anthropic/claude-3-haiku",
    "temperature": 0.7,
    "max_tokens": 2000
  },
  "pipeline": {
    "retry_attempts": 2,
    "timeout_seconds": 600,
    "parallel_stages": 1
  },
  "logging": {
    "level": "DEBUG",
    "structured": true
  },
  "rate_limit": {
    "default_limits": ["120/minute", "2000/hour"]
  }
}