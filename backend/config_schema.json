{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SEO Agent Configuration",
  "type": "object",
  "properties": {
    "model": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["openrouter"] },
        "model": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_tokens": { "type": "integer", "minimum": 1 }
      },
      "required": ["provider", "model"],
      "additionalProperties": false
    },
    "pipeline": {
      "type": "object",
      "properties": {
        "stages": {
          "type": "object",
          "patternProperties": {
            "^\w+$": { "type": "string", "enum": ["enabled", "disabled"] }
          },
          "additionalProperties": false
        },
        "retry_attempts": { "type": "integer", "minimum": 0, "maximum": 10 },
        "timeout_seconds": { "type": "integer", "minimum": 60, "maximum": 3600 },
        "parallel_stages": { "type": "integer", "minimum": 1, "maximum": 5 }
      },
      "additionalProperties": false
    },
    "rate_limit": {
      "type": "object",
      "properties": {
        "default_limits": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "per_ip_limits": {
          "type": "object",
          "patternProperties": {
            "^\w+": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] },
        "structured": { "type": "boolean" },
        "log_file_size_mb": { "type": "integer", "minimum": 1, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "properties": {
        "cors_origins": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 0
        },
        "api_key_required": { "type": "boolean" },
        "allowed_ips": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "required": ["model"]
}