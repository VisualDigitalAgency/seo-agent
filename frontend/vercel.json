{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "env": {
    "BACKEND_URL": "@backend-url",
    "NEXT_PUBLIC_BACKEND_URL": "@backend-url"
  },
  "headers": [
    {
      "source": "/api/stream/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-transform" },
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ]
}
